{
    "build": {
      "development": {
        "developmentClient": true,
        "distribution": "internal",
        "env": {
          "EXPO_PUBLIC_API_URL": "http://10.0.2.2:8000" 
        }
      },
      "preview": {
        "distribution": "internal",
        "env": {
          "EXPO_PUBLIC_API_URL": "https://你的正式版Lambda-URL.on.aws"
        }
      },
      "production": {
        "distribution": "store",
        "env": {
          "EXPO_PUBLIC_API_URL": "https://你的正式版Lambda-URL.on.aws"
        }
      }
    },
    "submit": {
      "production": {
        "ios": {
          "appleId": "你的AppleID",
          "ascAppId": "你的AppStoreConnectID",
          "appleTeamId": "你的AppleTeamID"
        },
        "android": {
          "serviceAccountKeyPath": "./android-service-account.json"
        }
      }
    }
  }